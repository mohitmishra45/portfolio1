{
    "name": "portfolio-root",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "client",
        "server"
    ],
    "scripts": {
        "dev": "concurrently \"npm run start:server\" \"npm run start:client\"",
        "start:server": "npm run dev -w server",
        "start:client": "npm run dev -w client",
        "build": "cd client && npm install && npm run build"
    },
    "devDependencies": {
        "concurrently": "^8.2.2",
        "vite": "^7.3.1",
        "tailwindcss": "^4.2.1",
        "autoprefixer": "^10.4.27",
        "postcss": "^8.5.8"
    }
}