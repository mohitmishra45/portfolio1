{
    "name": "portfolio-root",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "client",
        "server"
    ],
    "scripts": {
        "dev": "concurrently \"npm run start:server\" \"npm run start:client\"",
        "start:server": "npm run dev -w server",
        "start:client": "npm run dev -w client",
        "build": "npm run build -w client"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}